{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "cloud-run-service input schema",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "project_id",
    "region",
    "resource_name_prefix",
    "container_image"
  ],
  "properties": {
    "project_id": {
      "type": "string",
      "minLength": 1
    },
    "region": {
      "type": "string",
      "minLength": 1
    },
    "resource_name_prefix": {
      "type": "string",
      "minLength": 1
    },
    "container_image": {
      "type": "string",
      "minLength": 1
    },
    "port": {
      "type": "number",
      "default": 8080
    },
    "env_vars": {
      "type": "object",
      "default": {},
      "additionalProperties": {
        "type": "string"
      }
    },
    "min_instances": {
      "type": "number",
      "default": 0
    },
    "max_instances": {
      "type": "number",
      "default": 10
    },
    "cpu": {
      "type": "string",
      "default": "1"
    },
    "memory": {
      "type": "string",
      "default": "512Mi"
    },
    "allow_unauthenticated": {
      "type": "boolean",
      "default": false
    }
  }
}