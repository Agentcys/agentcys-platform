{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "firestore-database input schema",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "project_id",
    "region",
    "resource_name_prefix"
  ],
  "properties": {
    "project_id": {
      "type": "string",
      "minLength": 1
    },
    "region": {
      "type": "string",
      "minLength": 1
    },
    "resource_name_prefix": {
      "type": "string",
      "minLength": 1
    },
    "database_id": {
      "type": "string",
      "default": "(default)"
    },
    "deletion_protection": {
      "type": "boolean",
      "default": true
    },
    "point_in_time_recovery": {
      "type": "boolean",
      "default": false
    }
  }
}